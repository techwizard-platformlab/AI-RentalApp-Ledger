# Normalize line endings to LF in the repository.
# On checkout: Windows gets CRLF for text files (via core.autocrlf),
# but CI/cloud runners always get LF — enforced here so shell scripts
# and YAML files never accidentally get CRLF, which breaks bash/runners.

# Default: auto-detect text files and normalize to LF
* text=auto eol=lf

# Explicitly LF — shell scripts, YAML, Terraform, Dockerfiles break with CRLF
*.sh           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.tf           text eol=lf
*.tfvars       text eol=lf
*.rego         text eol=lf
Dockerfile*    text eol=lf
Makefile       text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.py           text eol=lf

# Binary files — never touch line endings
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.zip          binary
*.tar.gz       binary
*.tfstate      binary
*.tfplan       binary
