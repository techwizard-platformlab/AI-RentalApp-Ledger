{
  "title": "RAG Assistant Metrics",
  "uid": "rag-metrics",
  "tags": ["rentalapp", "rag", "ai"],
  "panels": [
    {
      "id": 1,
      "title": "RAG Queries/sec",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0},
      "targets": [
        {"expr": "rate(rag_query_total[5m])", "legendFormat": "{{status}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 2,
      "title": "RAG Query P95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "title": "Avg Context Docs Retrieved",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {"expr": "rag_context_retrieved", "legendFormat": "Docs"}
      ]
    },
    {
      "id": 4,
      "title": "LLM Tokens Used (cumulative)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {"expr": "rag_llm_tokens_used_total", "legendFormat": "Tokens"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "title": "RAG Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "targets": [
        {
          "expr": "rate(rag_query_total{status='error'}[5m]) / rate(rag_query_total[5m])",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    }
  ],
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "schemaVersion": 38
}
