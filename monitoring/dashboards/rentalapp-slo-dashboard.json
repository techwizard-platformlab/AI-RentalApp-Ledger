{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "ArgoCD Deployments",
        "rawQuery": "changes(argocd_app_info{dest_namespace=~\"$namespace\"}[2m]) > 0",
        "showIn": 0,
        "step": "60s",
        "titleFormat": "ArgoCD Deploy",
        "type": "graph"
      }
    ]
  },
  "description": "rentalAppLedger SLO Dashboard — Service Health, Request Volume, Pod Health, Resource Usage",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Row 1: Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=\"api-gateway\", namespace=~\"$namespace\"}",
          "legendFormat": "API Gateway"
        }
      ],
      "title": "API Gateway Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=~\"$namespace\", job=~\"$service\"}[5m]))",
          "legendFormat": "RPS"
        }
      ],
      "title": "Current RPS",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\", namespace=~\"$namespace\"}[5m])) / sum(rate(http_requests_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 2000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\", job=~\"$service\"}[5m]))) * 1000",
          "legendFormat": "P95 Latency"
        }
      ],
      "title": "P95 Latency (ms)",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Row 2: Request Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{namespace=~\"$namespace\"}[$interval]))", "legendFormat": "{{job}}" }
      ],
      "title": "HTTP Requests/sec by Service (stacked)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 6 },
      "id": 12,
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{status_code=~\"5..\", namespace=~\"$namespace\"}[$interval]))", "legendFormat": "{{job}} 5xx" }
      ],
      "title": "HTTP 5xx Errors/sec by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 6 },
      "id": 13,
      "options": { "xField": "Value", "orientation": "horizontal" },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{namespace=~\"$namespace\"}[$interval]))) * 1000)",
          "legendFormat": "{{handler}}"
        }
      ],
      "title": "Top 5 Slowest Endpoints (P95)",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "title": "Row 3: Pod Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Restarts" }, "properties": [{ "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color": "green","value": null},{"color": "yellow","value": 3},{"color": "red","value": 5}] } }, { "id": "custom.displayMode", "value": "color-background" }] },
          { "matcher": { "id": "byName", "options": "CPU" }, "properties": [{ "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "Memory" }, "properties": [{ "id": "unit", "value": "bytes" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 21,
      "options": { "footer": { "show": false } },
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "Pod Restarts Table",
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "pod": "Pod", "container": "Container", "Value": "Restarts", "namespace": "Namespace" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "id": 22,
      "targets": [
        { "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h])", "legendFormat": "{{pod}}" }
      ],
      "title": "Pod Restarts (last 1h)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "count(kube_pod_status_phase{namespace=~\"$namespace\", phase=\"Running\"})", "legendFormat": "Running Pods" }
      ],
      "title": "Running Pods",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "title": "Row 4: Resource Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 23 },
      "id": 31,
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", job=~\"$service\", container!=\"\"}[$interval]))", "legendFormat": "{{pod}}" }
      ],
      "title": "CPU Usage % per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 23 },
      "id": 32,
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", job=~\"$service\", container!=\"\"})", "legendFormat": "{{pod}}" }
      ],
      "title": "Memory Usage per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":0.7},{"color":"red","value":0.85}] }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 23 },
      "id": 33,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$interval]))", "legendFormat": "Node CPU" }
      ],
      "title": "Node CPU Utilisation",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":0.7},{"color":"red","value":0.9}] }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 23 },
      "id": 34,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "1 - (avg(node_memory_MemAvailable_bytes) / avg(node_memory_MemTotal_bytes))", "legendFormat": "Node Memory" }
      ],
      "title": "Node Memory Utilisation",
      "type": "gauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rentalapp", "slo", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": { "text": "rental-dev", "value": "rental-dev" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(kube_namespace_labels, namespace)",
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "query": "label_values(kube_namespace_labels{namespace=~\"rental-.*\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_total{namespace=~\"$namespace\"}, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "query": "label_values(http_requests_total{namespace=~\"$namespace\"}, job)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "text": "5m", "value": "5m" },
        "hide": 0,
        "includeAll": false,
        "label": "Interval",
        "multi": false,
        "name": "interval",
        "options": [
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true,  "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" }
        ],
        "query": "1m,5m,15m",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "rentalAppLedger SLO Dashboard",
  "uid": "rentalapp-slo",
  "version": 1
}
