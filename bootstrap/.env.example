# =============================================================================
# Bootstrap configuration template — generic, multi-cloud
#
# HOW TO USE:
#   cp bootstrap/.env.example bootstrap/.env
#   Fill in values for your environment (no secrets go here)
#   bash bootstrap/bootstrap.sh
#   python bootstrap/set-github-secrets.py   ← after cloud login
#
# RULES:
#   bootstrap/.env         → gitignored — safe on disk (no secrets)
#   bootstrap/.env.example → committed — generic template only
#
# WHERE THINGS LIVE:
#   .env              → resource names, regions, org/repo, cloud config
#   Cloud Secrets     → subscription/project IDs, client IDs, PATs, webhooks
#                       Azure → Key Vault
#                       GCP   → Secret Manager
#   GitHub Secrets    → OIDC credentials, Terraform backend config
#
# MULTI-CLOUD:
#   Set CLOUD=azure | gcp | both
#   Fill the relevant section(s) below
# =============================================================================

# ── Cloud selection ───────────────────────────────────────────────────────────
# Options: azure | gcp | both
CLOUD=azure

# ── GitHub (public — not secrets) ────────────────────────────────────────────
GITHUB_ORG=<your-github-org>
GITHUB_REPO=<your-repo-name>

# ── Azure configuration ───────────────────────────────────────────────────────
# Non-sensitive only. IDs are resolved at runtime from az CLI / Key Vault.

# Region where resources are deployed
AZURE_LOCATION=eastus

# Platform resource group — shared across ALL projects on this account
# Contains: Managed Identity, Key Vault, Terraform state storage
PLATFORM_RG=<platform-resource-group>
PLATFORM_KV_NAME=<platform-keyvault-name>
PLATFORM_MI_NAME=<platform-managed-identity-name>

# App-specific shared resource group (e.g. for ACR)
AZURE_SHARED_RG=<app-shared-resource-group>

# Terraform state backend — storage account name printed by bootstrap.sh
TF_BACKEND_RG=<same-as-PLATFORM_RG>
TF_BACKEND_SA=<printed-by-bootstrap-sh>
TF_BACKEND_CONTAINER=tfstate

# Short location code used in resource names (e.g. eus2 for eastus2)
AZURE_LOCATION_SHORT=eus2

# ── GCP configuration ─────────────────────────────────────────────────────────
# Non-sensitive only. Service account email and project number resolved at runtime.

GCP_PROJECT_ID=<your-gcp-project-id>
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# GCS bucket for Terraform state (created by bootstrap.sh)
GCP_TF_STATE_BUCKET=<your-project-id>-tfstate

# Workload Identity Pool and Provider created by bootstrap.sh
GCP_WI_POOL=github-actions-pool
GCP_WI_PROVIDER=github-actions-provider

# =============================================================================
# SECRETS — stored in cloud secrets store ONLY — NEVER in this file
#
# Azure Key Vault:
#   azure-subscription-id, azure-tenant-id, azure-client-id
#   github-pat, argocd-github-pat, discord-webhook-url
#   openai-api-key, smtp-password
#
# GCP Secret Manager:
#   github-pat, argocd-github-pat, discord-webhook-url
#   openai-api-key, smtp-password, db-password, django-secret-key
#
# GitHub Secrets (set by set-github-secrets.py):
#   AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_SUBSCRIPTION_ID
#   TF_BACKEND_RG, TF_BACKEND_SA, PLATFORM_KV_NAME
#   GCP_PROJECT_ID, GCP_REGION, GCP_WORKLOAD_IDENTITY_PROVIDER, GCP_SERVICE_ACCOUNT
#   OPENAI_API_KEY, SMTP_PASSWORD, DISCORD_WEBHOOK_URL
# =============================================================================
