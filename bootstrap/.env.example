# =============================================================================
# rentalAppLedger — Bootstrap Configuration Template
#
# HOW TO USE:
#   cp bootstrap/.env.example bootstrap/.env
#   Fill in your real values in bootstrap/.env
#   bash bootstrap/azure/bootstrap.sh          ← creates storage, RGs, roles, federated creds
#   python bootstrap/set-github-secrets.py     ← pushes secrets to both GitHub repos
#
# RULES:
#   bootstrap/.env         → gitignored, holds real values — NEVER commit
#   bootstrap/.env.example → committed, safe template only — NO real values
#
# AUTH MODEL:
#   Azure → Managed Identity + OIDC federated credentials (no client secrets)
#   GCP   → Workload Identity Federation (no service account keys)
# =============================================================================

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_ORG=techwizard-platformlab
GITHUB_REPO=AI-RentalApp-Ledger
BUILD_REPO=RentalApp-Build

# Personal Access Token — classic PAT with 'repo' scope (needed to set secrets)
# Create at: https://github.com/settings/tokens/new
GITHUB_PAT=<your-github-pat>

# =============================================================================
# AZURE — Managed Identity (OIDC, no client secrets)
#
# Where to find these values:
#   AZURE_SUBSCRIPTION_ID  → az account show --query id -o tsv
#   AZURE_TENANT_ID        → az account show --query tenantId -o tsv
#   AZURE_CLIENT_ID        → az identity show --name <identity> --resource-group my-Rental-App --query clientId -o tsv
# =============================================================================

AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>

# Managed Identity name (created once in my-Rental-App via Azure Portal or az CLI)
AZURE_IDENTITY_NAME=automation-identity

# Managed Identity client ID — used as AZURE_CLIENT_ID in GitHub Secrets
AZURE_CLIENT_ID=<managed-identity-client-id>

# Permanent shared resource group (holds Identity, State Storage, ACR, Key Vault)
AZURE_SHARED_RG=my-Rental-App

# Azure region
AZURE_LOCATION=eastus

# =============================================================================
# Terraform state backend
# TF_BACKEND_SA is printed by bootstrap.sh after the storage account is created.
# Copy the value here, then re-run set-github-secrets.py to push it.
# =============================================================================
TF_BACKEND_SA=<printed-by-bootstrap-sh>
TF_BACKEND_CONTAINER=tfstate

# =============================================================================
# Shared Terraform outputs
# These are available AFTER the first azure_shared_apply pipeline run.
# Run: terraform -chdir=infrastructure/azure/shared output acr_name
#      terraform -chdir=infrastructure/azure/shared output key_vault_name
#      terraform -chdir=infrastructure/azure/shared output acr_login_server
# Then fill in and re-run set-github-secrets.py to push them.
# =============================================================================
ACR_NAME=<from-shared-terraform-output>
ACR_LOGIN_SERVER=<from-shared-terraform-output>
KEY_VAULT_NAME=<from-shared-terraform-output>

# =============================================================================
# GCP — Workload Identity Federation
# =============================================================================
GCP_PROJECT_ID=<your-gcp-project-id>
GCP_REGION=us-central1

# =============================================================================
# Notifications (all optional)
# =============================================================================
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>
SMTP_PASSWORD=<your-gmail-app-password>
MAIL_TO=<alert-recipient-email>

# =============================================================================
# Build repo — Docker Hub (techwizard-platformlab/RentalApp-Build)
# =============================================================================
DOCKERHUB_USERNAME=<your-dockerhub-username>
DOCKERHUB_TOKEN=<your-dockerhub-access-token>

# =============================================================================
# AI / ML keys (optional — enables RAG API and AI tools)
# =============================================================================
GROQ_API_KEY=<your-groq-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
