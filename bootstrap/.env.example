# =============================================================================
# rentalAppLedger — Bootstrap Configuration Template
#
# HOW TO USE:
#   cp bootstrap/.env.example bootstrap/.env
#   Fill in your real values in bootstrap/.env
#   bash bootstrap/bootstrap.sh
#
# RULES:
#   bootstrap/.env         -> gitignored, holds real values, NEVER commit
#   bootstrap/.env.example -> committed, safe template only, NO real values
#
# KODEKLOUD CONSTRAINTS (hard limits that cannot be worked around):
#   - Cannot create or modify role definitions / assignments (BLOCKED)
#   - Cannot create additional resource groups (BLOCKED)
#   - Cannot elevate access (BLOCKED)
#   - Cannot purchase marketplace items (BLOCKED)
#   - Cannot access billing / cost information (BLOCKED)
#   - Lab user CLI login fails due to MFA / conditional access (use az login)
#   - SP client secret expires every KodeKloud session
#   - KodeKloud internally pre-grants the SP Contributor access to the RG
# =============================================================================

# ── Cloud selection ───────────────────────────────────────────────────────────
# Valid values: azure | gcp | both
CLOUD=azure

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_ORG=<your-github-username-or-org>
GITHUB_REPO=AI-RentalApp-Ledger

# Personal Access Token — 'repo' scope (classic) or 'secrets:write' (fine-grained)
# Create at: https://github.com/settings/tokens/new
GITHUB_PAT=<your-github-pat>

# =============================================================================
# AZURE — KodeKloud Lab
#
# Where to find these values:
#   AZURE_SUBSCRIPTION_ID  -> az account show --query id -o tsv
#   AZURE_RG               -> shown on KodeKloud lab dashboard
#   AZURE_TENANT_ID        -> az account show --query tenantId -o tsv
#   AZURE_APP_ID           -> az ad sp list --display-name <sp-name> --query [0].appId -o tsv
#   AZURE_CLIENT_SECRET    -> Azure Portal -> App Registrations -> Certificates & Secrets
#   AZURE_LAB_USERNAME     -> shown on KodeKloud lab dashboard
# =============================================================================

# Your KodeKloud lab subscription UUID
AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# Pre-existing resource group created by KodeKloud for your lab
AZURE_RG=<your-resource-group-name>

# Region — KodeKloud allows: eastus | westus | centralus | southcentralus
AZURE_LOCATION=eastus

# Tenant ID (GUID or domain form, e.g. yourtenant.onmicrosoft.com)
AZURE_TENANT_ID=<your-tenant-id>

# Pre-existing SP app (client) ID — DO NOT change; KodeKloud pre-grants access
AZURE_APP_ID=<your-service-principal-app-id>

# Client secret generated for the SP in Azure Portal
# WARNING: expires every KodeKloud lab session — regenerate each time
AZURE_CLIENT_SECRET=<your-client-secret>

# Lab username — informational only, not used for login
AZURE_LAB_USERNAME=<your-lab-username>

# ── Optional — Debug ──────────────────────────────────────────────────────────
# Set to 1 to print all loaded .env values at startup (passwords masked)
BOOTSTRAP_DEBUG=0

# =============================================================================
# GCP — KodeKloud pre-provides project; fill from lab dashboard
# =============================================================================

# GCP project ID (run: gcloud config get-value project)
GCP_PROJECT_ID=<your-gcp-project-id>

# GCP lab service account email (pre-created by KodeKloud, if provided)
GCP_LAB_SA_EMAIL=<your-gcp-service-account-email>

# Region — KodeKloud: US regions only
GCP_REGION=us-central1

# =============================================================================
# Terraform backend (filled in by bootstrap.sh after storage account creation)
# =============================================================================
TF_BACKEND_SA=<your-storage-account-name>
TF_BACKEND_CONTAINER=tfstate

# =============================================================================
# Notifications (all optional)
# =============================================================================
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>
MAIL_USERNAME=<your-gmail-address>
MAIL_PASSWORD=<your-gmail-app-password>
MAIL_TO=<alert-recipient-email>

# =============================================================================
# AI / ML keys (optional)
# =============================================================================
GROQ_API_KEY=<your-groq-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
