# =============================================================================
# rentalAppLedger — Bootstrap configuration template
#
# HOW TO USE:
#   cp bootstrap/.env.example bootstrap/.env
#   Fill in ONLY the non-sensitive values below (names, locations, org/repo).
#   bash bootstrap/bootstrap.sh
#   python bootstrap/set-github-secrets.py   ← after az login
#
# RULES:
#   bootstrap/.env         → gitignored — safe to keep on disk (no secrets)
#   bootstrap/.env.example → committed, safe template
#
# WHAT GOES WHERE:
#   .env              → resource names, locations, org/repo (non-sensitive only)
#   Key Vault         → azure-subscription-id, azure-client-id, azure-tenant-id,
#                        github-pat, argocd-github-pat, rentalapp-discord-webhook
#   GitHub Secrets    → AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_SUBSCRIPTION_ID,
#                        TF_BACKEND_*, TF_SHARED_RG, TF_GITHUB_ACTIONS_PRINCIPAL_ID
#
# TWO-TIER RESOURCE GROUP MODEL:
#   PLATFORM_RG     → central RG shared across ALL apps (MI + Key Vault + TF state)
#   AZURE_SHARED_RG → app-specific RG for this project  (ACR)
# =============================================================================

# ── Cloud selection ───────────────────────────────────────────────────────────
CLOUD=azure

# ── GitHub (org/repo names — public, not secrets) ────────────────────────────
GITHUB_ORG=<your-github-org>
GITHUB_REPO=<your-app-repo>
BUILD_REPO=<your-build-repo>

# ── Platform RG (shared across ALL your apps) ─────────────────────────────────
# Contains: Managed Identity, Key Vault, Terraform state storage
PLATFORM_RG=techwizard-platformlab-apps
PLATFORM_KV_NAME=techwizard-plt-kv
PLATFORM_MI_NAME=automation-identity

# ── Azure location ────────────────────────────────────────────────────────────
# AZURE_SUBSCRIPTION_ID, AZURE_TENANT_ID, AZURE_CLIENT_ID are NOT stored here.
# bootstrap.sh resolves them at runtime from: az account show / az identity show
# Store them in Key Vault: azure-subscription-id, azure-tenant-id, azure-client-id
AZURE_LOCATION=eastus

# ── App-specific RG (ACR for this project only) ───────────────────────────────
AZURE_SHARED_RG=my-Rental-App

# ── Terraform state backend ───────────────────────────────────────────────────
# TF_BACKEND_RG  = PLATFORM_RG (state lives in techwizard-platformlab-apps)
# TF_BACKEND_SA  = printed by bootstrap.sh after storage account is created
# TF_GITHUB_ACTIONS_PRINCIPAL_ID = resolved at runtime via az identity show
TF_BACKEND_RG=techwizard-platformlab-apps
TF_SHARED_RG=my-Rental-App
TF_BACKEND_SA=<printed-by-bootstrap-sh>
TF_BACKEND_CONTAINER=tfstate

# ── Populated after first Terraform shared apply ──────────────────────────────
# terraform -chdir=infrastructure/azure/shared output -raw acr_name
ACR_NAME=
ACR_LOGIN_SERVER=

# ── GCP (non-sensitive config only) ──────────────────────────────────────────
#GCP_PROJECT_ID=<your-gcp-project-id>
#GCP_REGION=us-central1

# =============================================================================
# SECRETS — stored in Key Vault: techwizard-plt-kv  (NEVER in this file)
#
#   azure-subscription-id      → AZURE_SUBSCRIPTION_ID
#   azure-tenant-id            → AZURE_TENANT_ID
#   azure-client-id            → AZURE_CLIENT_ID
#   github-pat                 → GitHub PAT (repo scope)
#   argocd-github-pat          → GitHub PAT for ArgoCD repo access
#   rentalapp-discord-webhook  → Discord webhook URL
# =============================================================================
