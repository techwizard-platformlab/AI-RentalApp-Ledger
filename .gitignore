# =============================================================================
# rentalAppLedger — .gitignore
# Scanned and verified — no credentials, secrets, or sensitive data committed.
# =============================================================================

# ── Terraform ─────────────────────────────────────────────────────────────────
# terraform.tfvars IS committed (non-secret env config)
# terraform.tfvars.example IS committed (safe template)
*.tfvars.local
*.tfvars.secret
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
tfplan.binary
tfplan.json
plan.txt
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Environment / secrets — NEVER commit ──────────────────────────────────────
.env
.env.*
# Allow .env.example template files (no real values)
!.env.example
!bootstrap/.env.example

# ── Credentials / keys — NEVER commit ─────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
# GCP service account JSON keys (use Workload Identity instead)
*-sa-key.json
*-credentials.json
*service-account*.json
*-keyfile.json
gcp-key*.json
*-sa.json
# Any file explicitly named secrets or credentials
secrets.yaml
secrets.yml
credentials.yaml
credentials.yml
*-secret-values.yaml
*-secret-values.yml

# ── Kubeconfig ────────────────────────────────────────────────────────────────
kubeconfig
kubeconfig.yaml
kubeconfig.yml
*.kubeconfig
.kube/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.env.bak
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.prof

# ── Test / QA reports ─────────────────────────────────────────────────────────
qa/reports/
qa/*.html
*.html
behave-report.json
test-results/
junit*.xml

# ── RAG / Database ────────────────────────────────────────────────────────────
rag/data/
rag/chroma/
rag/chroma_db/
*.db
*.sqlite
*.sqlite3
chroma_data/
# watermark file — runtime state, not source
last_indexed.json

# ── Infracost ─────────────────────────────────────────────────────────────────
infracost-output.json
infracost-diff.json
infracost*.json
# .infracost/config.yml IS committed (project config, no secrets)

# ── Docker ────────────────────────────────────────────────────────────────────
*.tar
*.tar.gz

# ── Helm ──────────────────────────────────────────────────────────────────────
.helm/
charts/
*.tgz

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Temp / runtime ────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo
*~
.cache/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.code-workspace
nbproject/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Node (if frontend added later) ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ── Claude Code local settings — NEVER commit ────────────────────────────────
.claude/settings.local.json
.claude/

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Real secrets — NEVER commit
bootstrap/.env
# bootstrap/.env.example is intentionally committed (no real values)

# ── ArgoCD / K8s runtime state ────────────────────────────────────────────────
argo-output/
*.kubeout

# ── Coverage / profiling ──────────────────────────────────────────────────────
coverage.xml
*.cover
.nyc_output/

# =============================================================================
# EXPLICITLY ALLOWED (override broad rules above where needed)
# These files ARE safe to commit — gitignore negation rules:
# =============================================================================

# Grafana dashboard JSON — safe (no secrets, just panel config)
!monitoring/dashboards/*.json

# Policy data JSON — safe (approved SKUs, cost baseline)
!policy/data/*.json

# Sample output JSON — safe (anonymised test data)
!ai-tools/anomaly-detector/sample-anomaly-output.json
